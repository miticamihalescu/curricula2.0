# ─────────────────────────────────────────────────────────
# Curricula 2.0 — Variabile de mediu
# Copiază acest fișier ca .env și completează valorile
# ─────────────────────────────────────────────────────────

# OBLIGATORIU: Cheie secretă pentru token-uri JWT
# Generează una sigură cu: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=schimba_cu_o_cheie_secreta_lunga_si_complexa

# OBLIGATORIU: Cheie API Google Gemini (pentru generarea materialelor didactice)
# Obține din: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# OBLIGATORIU: Conexiune MongoDB
# Local: mongodb://localhost:27017/curricula
# Cloud (MongoDB Atlas): mongodb+srv://user:parola@cluster.mongodb.net/curricula
MONGODB_URI=mongodb://localhost:27017/curricula

# EMAIL (Resend) — necesar pentru resetarea parolei
# Cont gratuit la: https://resend.com (3000 emails/lună gratuit)
RESEND_API_KEY=re_...

# URL-ul aplicației (folosit în email-urile de resetare parolă)
# Local: http://localhost:3000
# Producție: https://domeniul-tau.ro
APP_URL=http://localhost:3000

# Adresa de expeditor pentru email-uri
# Trebuie să fie pe un domeniu verificat în Resend
# Pentru testare locală poți folosi: onboarding@resend.dev
EMAIL_FROM=Curricula <noreply@curricula.ro>

# Portul serverului (opțional, implicit 3000)
PORT=3000

# Mediul de rulare: development | production | test
NODE_ENV=development
